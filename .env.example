# ── OpenClaw Gateway ──────────────────────────────────────────────
# Required: secret token used to authenticate to the Control UI and API
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-secret

# Port Railway's HTTP proxy routes to (must match the value in railway.json healthcheckPath)
OPENCLAW_GATEWAY_PORT=8080

# State and workspace dirs — point both at the Railway persistent volume
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# ── AI Provider ───────────────────────────────────────────────────
# Anthropic API key (claude-cli OAuth does not work headlessly on Railway)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Plugins (optional) ────────────────────────────────────────────
# Tavily web search — https://app.tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# ── HEX OS sync (optional, only needed if you run hex-sync.py here) ──
HEX_GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
